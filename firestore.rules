rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── Products ──────────────────────────────────────────────
    match /products/{productId} {
      allow read:                    if true;
      allow create, update, delete:  if isAdmin();
    }

    // ── Categories ────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────
    // Authenticated users can create orders for themselves.
    // Guest orders are blocked — checkout now requires login.
    match /orders/{orderId} {
      allow read:   if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth() && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Hero Slides (public read, admin write) ────────────────
    match /heroSlides/{slideId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Store Settings (public read, admin write) ─────────────
    match /settings/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Logins (activity tracking) ────────────────────────────
    match /logins/{loginId} {
      allow read:   if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── Reviews ───────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read:           if true;
      allow create:         if isAuth();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
