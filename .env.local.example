# ============================================================
# COMPUNIL — Environment Variables
# 1. Copy this file:  cp .env.local.example .env.local
# 2. Paste your real Firebase values below
# 3. NEVER commit .env.local to version control (it's in .gitignore)
# ============================================================

# ── Firebase Configuration ──────────────────────────────────
# Source: Firebase Console → Project Settings → General → Your apps → SDK setup
#         Copy the values from the firebaseConfig = { ... } object shown there

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NOTE: Newer Firebase projects use .firebasestorage.app (NOT .appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── App Config ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Compunil
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_EMAIL=admin@compunil.com
